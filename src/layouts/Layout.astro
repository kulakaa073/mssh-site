---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

type Breadcrumb = { label: string; href?: string };

type Props = {
	title?: string;
	description?: string;
	breadcrumbs?: Breadcrumb[];
	pageTitle?: string;
	noBanner?: boolean;
};

const {
	title,
	description,
	breadcrumbs,
	pageTitle,
	// reserved for Phase 3 (PageBanner)
	noBanner: _noBanner
} = Astro.props as Props;

let contacts: any = null;
try {
	// This file is created in Phase 1 (`src/content/settings/contacts.md`)
	const mod = await import('../content/settings/contacts.md');
	contacts = (mod as any)?.frontmatter ?? null;
} catch {
	contacts = null;
}

const siteTitle =
	title ??
	contacts?.schoolName ??
	'КЗО «Магдалинівська спеціальна школа» ДОР';
---

<!doctype html>
<html lang="uk">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>{siteTitle}</title>
		{description ? <meta name="description" content={description} /> : null}

		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
	</head>
	<body class="min-h-dvh bg-white text-slate-900">
		<a
			href="#main"
			class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-white focus:px-3 focus:py-2 focus:text-sm focus:shadow"
		>
			Перейти до вмісту
		</a>

		<Header
			contacts={contacts}
			breadcrumbs={breadcrumbs}
			pageTitle={pageTitle}
		/>

		<main id="main">
			<slot />
		</main>

		<Footer contacts={contacts} />
	</body>
</html>
