---
type Breadcrumb = { label: string; href?: string };

type Props = {
  contacts?: {
    schoolName?: string;
  } | null;
  breadcrumbs?: Breadcrumb[];
  pageTitle?: string;
};

const { contacts } = Astro.props as Props;

const schoolName =
  contacts?.schoolName ??
  'Комунальний заклад освіти «Магдалинівська спеціальна школа» Дніпропетровської обласної ради»';

type NavItem = { label: string; href?: string; children?: NavItem[] };

const docCategoryModules = await Astro.glob('../content/public-info/document-categories/*.md');
const eventCategoryModules = await Astro.glob('../content/educational-process/event-categories/*.md');

const documentCategories = docCategoryModules
  .map((mod: any) => mod.frontmatter as { title: string; slug: string; order?: number })
  .sort((a, b) => (a.order ?? 0) - (b.order ?? 0))
  .map((c) => ({
    label: c.title,
    href: `/publichna-informatsiya/${c.slug}`
  }));

const eventCategories = eventCategoryModules
  .map((mod: any) => mod.frontmatter as { title: string; slug: string; order?: number })
  .sort((a, b) => (a.order ?? 0) - (b.order ?? 0))
  .map((c) => ({
    label: c.title,
    href: `/vykhovnyj-protses/${c.slug}`
  }));

const nav: NavItem[] = [
  { label: 'Головна', href: '/' },
  {
    label: 'Про школу',
    children: [
      { label: 'Адміністрація', href: '/pro-shkolu/administratsiya' },
      { label: 'Структура закладу', href: '/pro-shkolu/struktura' },
      { label: 'Історична довідка', href: '/pro-shkolu/istorychna-dovidka' }
    ]
  },
  {
    label: 'Публічна інформація',
    children: documentCategories
  },
  {
    label: 'Виховний процес',
    children: eventCategories
  },
  { label: 'Контакти', href: '/kontakty' }
];
---

<header class="header-main w-full">
  <!-- Top header block (OG: centered logo + name) -->
  <div class="top-header w-full">
    <div class="mx-auto flex max-w-6xl justify-center px-4 py-6">
    <a href="/" class="group flex flex-col items-center gap-3 text-center">
      <div
        class="grid size-12 place-items-center rounded-full bg-[radial-gradient(circle_at_30%_30%,#feca16,#f39)] text-white shadow-lg"
        aria-hidden="true"
      >
        <span class="text-sm font-semibold text-slate-500">Лого</span>
      </div>
      <div class="text-pretty text-lg font-semibold leading-snug tracking-tight text-slate-900">
        {schoolName}
      </div>
    </a>
  </div>

    </a>
    </div>
  </div>

  <!-- Primary nav block -->
  <div class="menu-block w-full border-y border-[#e7e7e7] bg-white">
    <div class="mx-auto max-w-6xl px-4">
      <div class="flex items-center justify-between gap-4 py-3">
        <form action="/poshuk" class="hidden items-center gap-2 md:flex">
          <input
            type="search"
            name="q"
            placeholder="Пошук тексту..."
            class="w-64 rounded-md border border-slate-300 bg-white px-3 py-2 text-sm outline-none ring-0 placeholder:text-slate-400 focus:border-slate-400"
          />
          <button
            type="submit"
            class="rounded-md bg-slate-900 px-3 py-2 text-sm font-medium text-white hover:bg-slate-800"
          >
            Пошук
          </button>
        </form>

        <details class="md:hidden">
          <summary
            class="cursor-pointer select-none rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-medium"
          >
            Меню
          </summary>
          <nav class="mt-3 rounded-lg border border-slate-200 bg-white p-2">
            <ul class="flex flex-col">
              {
                nav.map((item) => (
                  <li class="border-b border-slate-100 last:border-b-0">
                    {item.href ? (
                      <a class="block px-3 py-2 text-sm hover:bg-slate-50" href={item.href}>
                        {item.label}
                      </a>
                    ) : (
                      <details>
                        <summary class="cursor-pointer select-none px-3 py-2 text-sm hover:bg-slate-50">
                          {item.label}
                        </summary>
                        <ul class="pb-2 pl-2">
                          {item.children?.map((c) => (
                            <li>
                              <a class="block px-3 py-2 text-sm text-slate-700 hover:bg-slate-50" href={c.href}>
                                {c.label}
                              </a>
                            </li>
                          ))}
                        </ul>
                      </details>
                    )}
                  </li>
                ))
              }
            </ul>
          </nav>
        </details>
      </div>

      <nav class="ow-navigation hidden md:block">
        <ul class="nav navbar-nav menubar flex flex-wrap items-center gap-1 pb-3">
          {
            nav.map((item) => (
              <li class={item.children ? 'dropdown' : ''}>
                {item.href ? (
                  <a
                    href={item.href}
                    class="dropdown-toggle"
                  >
                    {item.label}
                  </a>
                ) : (
                  <>
                    <a
                      href="#"
                      class="dropdown-toggle"
                      role="button"
                      aria-haspopup="true"
                      aria-expanded="false"
                    >
                      {item.label}
                    </a>
                    <i class="ddl-switch fa fa-angle-down"></i>
                    <ul class="dropdown-menu">
                      {item.children?.map((c) => (
                        <li>
                          <a href={c.href}>{c.label}</a>
                        </li>
                      ))}
                    </ul>
                  </>
                )}
              </li>
            ))
          }
        </ul>
      </nav>
    </div>
  </div>
</header>

