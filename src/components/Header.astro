---
import { getCollection } from 'astro:content';
import { COLLECTIONS } from '../lib/content/collections';

type Breadcrumb = { label: string; href?: string };

type Props = {
  contacts?: {
    schoolName?: string;
  } | null;
  breadcrumbs?: Breadcrumb[];
  pageTitle?: string;
};

const { contacts } = Astro.props as Props;

const schoolName =
  contacts?.schoolName ??
  'Комунальний заклад освіти «Магдалинівська спеціальна школа» Дніпропетровської обласної ради»';

type NavItem = { label: string; href?: string; children?: NavItem[] };

type CategoryEntryData = {
  title?: string;
  slug?: string;
  order?: number | string;
};

function parseOrder(order: number | string | undefined): number | undefined {
  if (typeof order === 'number' && Number.isFinite(order)) return order;
  if (typeof order === 'string') {
    const parsed = Number(order);
    return Number.isFinite(parsed) ? parsed : undefined;
  }
  return undefined;
}

function sortCategories(a: CategoryEntryData, b: CategoryEntryData): number {
  const aOrder = parseOrder(a.order);
  const bOrder = parseOrder(b.order);
  if (aOrder !== undefined && bOrder !== undefined) return aOrder - bOrder;
  if (aOrder !== undefined) return -1;
  if (bOrder !== undefined) return 1;
  return (a.title ?? '').localeCompare(b.title ?? '', 'uk');
}

function toNavItem(category: CategoryEntryData, basePath: string): NavItem | undefined {
  const slug = category.slug?.trim();
  const label = category.title?.trim();
  if (!slug || !label) return undefined;
  return {
    label,
    href: `${basePath}/${slug}`
  };
}

const documentCategoryEntries = await getCollection(COLLECTIONS.documentCategories);
const eventCategoryEntries = await getCollection(COLLECTIONS.eventCategories);

const documentCategories = documentCategoryEntries
  .map((entry) => entry.data as CategoryEntryData)
  .sort(sortCategories)
  .map((category) => toNavItem(category, '/publichna-informatsiya'))
  .filter((item): item is NavItem => Boolean(item));

const eventCategories = eventCategoryEntries
  .map((entry) => entry.data as CategoryEntryData)
  .sort(sortCategories)
  .map((category) => toNavItem(category, '/vykhovnyj-protses'))
  .filter((item): item is NavItem => Boolean(item));

const nav: NavItem[] = [
  { label: 'Головна', href: '/' },
  {
    label: 'Про школу',
    children: [
      { label: 'Адміністрація', href: '/pro-shkolu/administratsiya' },
      { label: 'Структура закладу', href: '/pro-shkolu/struktura' },
      { label: 'Історична довідка', href: '/pro-shkolu/istorychna-dovidka' }
    ]
  },
  {
    label: 'Публічна інформація',
    children: documentCategories
  },
  {
    label: 'Виховний процес',
    children: eventCategories
  },
  { label: 'Контакти', href: '/kontakty' }
];
---

<header class="header-main container-fluid no-padding">
  <div class="top-header container-fluid no-padding">
    <div class="container">
      <div class="row">
        <div class="logo-block">
          <a href="/" title="Logo">
            <img src="/assets/logo.png" alt="logo" width="46" height="41" />
          </a>
          <div class="entry-title">
            <h3>{schoolName}</h3>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="menu-block container-fluid no-padding">
    <div class="container">
      <div class="menu-search">
        <div id="sb-search" class="sb-search">
          <form action="/poshuk">
            <input class="sb-search-input" placeholder="Пошук тексту..." type="search" value="" name="q" />
            <button class="sb-search-submit" type="submit"><i class="fa fa-search"></i></button>
            <span class="sb-icon-search"></span>
          </form>
        </div>
      </div>
      <div class="col-md-10 col-sm-12">
        <nav class="navbar ow-navigation">
          <div class="navbar-header">
            <button
              aria-controls="navbar"
              aria-expanded="false"
              data-target="#navbar"
              class="navbar-toggle collapsed"
              type="button"
            >
              <span class="sr-only">Toggle navigation</span>
              <span class="icon-bar"></span>
              <span class="icon-bar"></span>
              <span class="icon-bar"></span>
            </button>
            <a title="Logo" href="/" class="navbar-brand">
              <img src="/assets/logo.png" alt="logo" />
              <span>КЗО «Магдалинівська спеціальна школа» ДОР»</span>
            </a>
          </div>
          <div class="navbar-collapse collapse" id="navbar">
            <ul class="nav navbar-nav menubar">
              {
                nav.map((item) => (
                  <li class={item.children ? 'dropdown' : ''}>
                    {item.href ? (
                      <a href={item.href}>{item.label}</a>
                    ) : (
                      <>
                        <a aria-expanded="false" aria-haspopup="true" role="button" class="dropdown-toggle" href="#">
                          {item.label}
                        </a>
                        <i class="ddl-switch fa fa-angle-down"></i>
                        <ul class="dropdown-menu">
                          {item.children?.map((c) => (
                            <li><a href={c.href}>{c.label}</a></li>
                          ))}
                        </ul>
                      </>
                    )}
                  </li>
                ))
              }
            </ul>
          </div>
        </nav>
      </div>
    </div>
  </div>
</header>

<script>
  const navToggle = document.querySelector('.menu-block .navbar-toggle');
  const navCollapse = document.querySelector('.menu-block .navbar-collapse');
  if (navToggle instanceof HTMLButtonElement && navCollapse instanceof HTMLElement) {
    navToggle.addEventListener('click', () => {
      const isOpen = navCollapse.classList.contains('in');
      navCollapse.classList.toggle('in', !isOpen);
      navCollapse.style.display = isOpen ? 'none' : 'block';
      navToggle.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
      navToggle.classList.toggle('collapsed', isOpen);
    });
  }

  document.querySelectorAll('.menu-block .ddl-switch').forEach((switchEl) => {
    switchEl.addEventListener('click', (event) => {
      const target = event.currentTarget;
      if (!(target instanceof HTMLElement)) return;
      const parent = target.closest('li');
      const menu = parent?.querySelector(':scope > .dropdown-menu');
      if (!(parent instanceof HTMLElement) || !(menu instanceof HTMLElement)) return;
      parent.classList.toggle('ddl-active');
      const isActive = parent.classList.contains('ddl-active');
      menu.style.display = isActive ? 'block' : 'none';
    });
  });

  const searchWrapper = document.querySelector('.menu-search .sb-search');
  const searchIcon = document.querySelector('.menu-search .sb-icon-search');
  if (searchWrapper instanceof HTMLElement && searchIcon instanceof HTMLElement) {
    searchIcon.addEventListener('click', () => {
      searchWrapper.classList.toggle('sb-search-open');
    });
  }
</script>

