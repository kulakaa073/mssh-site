---
type Props = {
  contacts?: {
    schoolName?: string;
    address?: string;
    phoneMain?: string;
    phoneAdditional?: string[];
    email?: string;
    workingHours?: string;
    socialLinks?: { label?: string; url?: string }[];
  } | null;
};

const { contacts } = Astro.props as Props;
const hasAddress = Boolean(contacts?.address?.trim());
const hasPhone = Boolean(contacts?.phoneMain?.trim());
const hasEmail = Boolean(contacts?.email?.trim());
const year = new Date().getFullYear();
---

<footer class="footer-main container-fluid no-padding">
  <div class="container">
    <div class="row">
      <aside class="col-md-3 col-sm-6 col-xs-6 widget widget_contactus">
        <h3 class="block-title">Контакти</h3>
        <div class="contactinfo-box">
          <i class="fa fa-map-marker"></i>
          <p>{hasAddress ? contacts?.address : 'Інформація оновлюється.'}</p>
        </div>
        <div class="contactinfo-box">
          <i class="fa fa-phone"></i>
          <p>
            {hasPhone ? (
              <a href={`tel:${contacts?.phoneMain}`}>{contacts?.phoneMain}</a>
            ) : (
              <span>Інформація оновлюється.</span>
            )}
            {contacts?.phoneAdditional?.filter(Boolean).map((phone) => (
              <a href={`tel:${phone}`}>{phone}</a>
            ))}
          </p>
        </div>
        <div class="contactinfo-box">
          <i class="fa fa-envelope"></i>
          <p>
            {hasEmail ? (
              <a href={`mailto:${contacts?.email}`}>{contacts?.email}</a>
            ) : (
              <span>Інформація оновлюється.</span>
            )}
          </p>
        </div>
      </aside>

      <aside class="col-md-4 col-sm-6 col-xs-6 widget widget_newsletter">
        <h3 class="block-title">Адміністрація</h3>
        <p>Інформація буде оновлена відповідно до заповнення розділу у CMS.</p>
      </aside>
    </div>
  </div>

  <div class="container">
    <div class="footer-menu">
      <div class="copyrights ow-pull-left">
        <p>&copy; {year} | {contacts?.schoolName ?? 'КЗО «Магдалинівська спеціальна школа» ДОР»'}</p>
      </div>
      <nav class="navbar ow-navigation ow-pull-right">
        <div class="navbar-header">
          <button aria-controls="navbar" aria-expanded="false" data-target="#navbar2" class="navbar-toggle collapsed" type="button">
            <span class="sr-only">Toggle navigation</span>
            <span class="icon-bar"></span>
            <span class="icon-bar"></span>
            <span class="icon-bar"></span>
          </button>
        </div>
      </nav>
    </div>
  </div>
</footer>

